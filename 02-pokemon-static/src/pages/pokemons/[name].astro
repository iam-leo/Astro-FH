---
import type { GetStaticPaths } from 'astro';
import MainLayout from '@layouts/MainLayout.astro';
import PokemonCard from '@components/pokemons/PokemonCard.astro';
import type { PokemonListResponse } from '@interfaces/pokemon-list-results';
import Title from '@components/shared/Title.astro';
import { Icon } from 'astro-icon/components';

const { name } = Astro.params;

const { url } = Astro.props;

const id = url.split('/').at(-2);

const audioUrl = `https://raw.githubusercontent.com/PokeAPI/cries/main/cries/pokemon/latest/${id}.ogg`;

const imageUrl = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${id}.png`;

export const getStaticPaths = (async () => {
    const resp = await fetch('https://pokeapi.co/api/v2/pokemon?limit=151');

    const { results } = (await resp.json()) as PokemonListResponse;

    return results.map((pokemon) => ({
        params: { name: pokemon.name },
        props: { url: pokemon.url },
    }));
}) satisfies GetStaticPaths;
---

<MainLayout
    title={`Pokemon #${id} ${name}`}
    description={`Información del Pokémon ${name}`}
    image={imageUrl}
>
    <section
        class='w-full bg-slate-800 rounded p-3 text-center capitalize my-14'
    >
        <div class="flex flex-row justify-center items-center gap-x-4">
            <Title class='capitalize'>
                #{id} - {name}
            </Title>

            <button
                data-name={ name }
                data-id={ id }
                id="btn-favorite"
                class="cursor-pointer hover:animate-pulse"
            >
                <Icon name='heart-outline' class="size-14" />
                <Icon name='heart-full' class="size-14 hidden" />
            </button>
        </div>

        <div class='max-w-xs mx-auto mt-5'>
            <PokemonCard
                name={name}
                url={url}
                isBig
            />
        </div>

        <audio
            controls
            class='mx-auto mt-5'
        >
            <source
                src={audioUrl}
                type='audio/mpeg'
            />
            Your browser does not support the audio element.
        </audio>

        <button
            onclick='history.back()'
            class='text-white mt-5 hover:text-indigo-100 transition-colors bg-indigo-900 hover:bg-indigo-800 px-5 py-2 rounded-full cursor-pointer'
        >
            Regresar
        </button>
    </section>
</MainLayout>

<script>
    interface FavoritePokemon {
        id: number;
        name: string;
    }

    const handlePageLoad = () => {
        const btnFavorite = document.querySelector('#btn-favorite') as HTMLButtonElement;

        if (!btnFavorite) return;

        const name = btnFavorite.dataset.name;
        const id = btnFavorite.dataset.id;

        btnFavorite.addEventListener('click', () => {
            console.log({ name, id });
        });
    };

    document.addEventListener('astro:page-load', handlePageLoad );


</script>